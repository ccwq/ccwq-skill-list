# rd-mode 远程开发配置示例
# 用法：运行 `rd-mode --init` 自动生成，或手动复制到 ~/.config/rd-mode/.env 并填入真实值

# host 远端环境地址（必填）—— 有桌面/浏览器的远端机器 IP 或 hostname
export RHost="192.168.1.100"

# host 浏览器 CDP 远程调试端口（必填）
export CDP_PORT=9222

# CDP 连接地址（派生，自动生成，无需手改）
export CDP_URL="http://${RHost}:${CDP_PORT}"

# 取消所有代理（abc 连接 host 浏览器前必须，避免走代理连不上）
alias unproxy="unset HTTPS_PROXY HTTP_PROXY ALL_PROXY https_proxy http_proxy all_proxy"

# agent-browser 的 CDP 封装：连接 host 浏览器
alias abc="unproxy; agent-browser --cdp ${CDP_URL}"
alias agent-browser-cli="abc"
